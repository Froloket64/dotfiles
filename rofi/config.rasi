configuration {
	modi: "window,run,drun,ssh";
	width: 100;
	font: "JetBrainsMono NF 12";    // Font setting (set's the font to default,
	// if the specified one is not found)
	location: 2;    // Location on the screen. Values are integers from 0 to 8,
	// as described in the following table (position in the table represents position on screen):
	//  1 2 3
	//  8 0 4
	//  7 6 5
	show-icons: true;    // Show icons for options (essentially, apps)
