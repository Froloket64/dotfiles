/*	disable-history: false;*/
/*	ignored-prefixes: "";*/
	sort: false;    // Sort options (Not sure, which values are possible here)
/*	sorting-method: ;*/
	case-sensitive: false;
	cycle: false;    // Cycle to bottom when hit top and vise-versa
/*	sidebar-mode: false;*/
/*	eh: 1;*/
	auto-select: false;    // Automatically hit <Enter> (select the option) if there's only one option left
